# AI Venting Machine - Environment Configuration
# Copy this file to .env.local and add your API keys

# MOONSHOT (Kimi) - RECOMMENDED
# Get yours at: https://platform.moonshot.ai/console/api-keys
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Google Gemini - Alternative
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI - Alternative
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic - Alternative
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Enable debug mode for verbose logging
# VITE_DEBUG_MODE=true
